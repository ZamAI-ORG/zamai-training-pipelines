# Environment Variables for ZamAI Pro Models Strategy

# Hugging Face Configuration
HF_TOKEN=your_hugging_face_token_here
HF_ORG=tasal9

# Your Existing Model Repositories
MISTRAL_EDU_MODEL=tasal9/ZamAI-Mistral-7B-Pashto
PHI3_BUSINESS_MODEL=tasal9/ZamAI-Phi-3-Mini-Pashto
WHISPER_MODEL=tasal9/ZamAI-Whisper-v3-Pashto
LLAMA3_MODEL=tasal9/ZamAI-LIama3-Pashto
BLOOM_MODEL=tasal9/pashto-base-bloom
EMBEDDINGS_MODEL=tasal9/Multilingual-ZamAI-Embeddings

# Dataset Repositories (Private)
PASHTO_SPEECH_DATASET=zamai-org/pashto-speech-data
EDUCATION_QA_DATASET=zamai-org/pashto-education-qa
BUSINESS_DOCS_DATASET=zamai-org/business-documents

# Endpoint Configuration
MISTRAL_ENDPOINT_NAME=mistral-edu-endpoint
PHI3_ENDPOINT_NAME=phi3-business-endpoint

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Training Configuration
BATCH_SIZE=4
LEARNING_RATE=2e-5
NUM_EPOCHS=3
MAX_LENGTH=512

# Gradio Configuration
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=False
